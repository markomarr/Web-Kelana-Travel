// Prisma schema — Kelana Travel
// Lihat PRD.md Section 5 untuk detail setiap tabel.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Singleton — selalu 1 row (id = 1)
model SiteSettings {
  id            Int      @id @default(1)
  siteName      String   @map("site_name") @db.VarChar(100)
  phoneWhatsapp String   @map("phone_whatsapp") @db.VarChar(20)
  phoneDisplay  String   @map("phone_display") @db.VarChar(25)
  email         String?  @db.VarChar(100)
  address       String?
  mapsEmbedUrl  String?  @map("maps_embed_url")
  heroTagline   String   @map("hero_tagline") @db.VarChar(200)
  heroSubtext   String?  @map("hero_subtext")
  heroImageUrl  String?  @map("hero_image_url")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model Vehicle {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(120)
  photoUrl    String?  @map("photo_url")
  capacity    Int      @db.SmallInt
  facilities  Json?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  routePrices RoutePrice[]

  @@index([isActive])
  @@map("vehicles")
}

model Route {
  id          String   @id @default(uuid()) @db.Uuid
  cityFrom    String   @map("city_from") @db.VarChar(100)
  cityTo      String   @map("city_to") @db.VarChar(100)
  durationEst String?  @map("duration_est") @db.VarChar(50)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  prices RoutePrice[]

  @@index([isActive])
  @@index([cityFrom])
  @@map("routes")
}

model RoutePrice {
  id        String @id @default(uuid()) @db.Uuid
  routeId   String @map("route_id") @db.Uuid
  vehicleId String @map("vehicle_id") @db.Uuid
  price     Int

  route   Route   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([routeId, vehicleId])
  @@map("route_prices")
}

model Testimonial {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  rating    Int      @db.SmallInt
  review    String
  routeUsed String?  @map("route_used") @db.VarChar(100)
  photoUrl  String?  @map("photo_url")
  published Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([published])
  @@map("testimonials")
}

model Feature {
  id          String @id @default(uuid()) @db.Uuid
  iconKey     String @map("icon_key") @db.VarChar(50)
  title       String @db.VarChar(100)
  description String
  order       Int    @db.SmallInt

  @@map("features")
}

model FaqItem {
  id       String @id @default(uuid()) @db.Uuid
  question String
  answer   String
  order    Int    @db.SmallInt

  @@index([order])
  @@map("faq_items")
}

model AdminUser {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(200)
  passwordHash String    @map("password_hash")
  name         String?   @db.VarChar(100)
  createdAt    DateTime  @default(now()) @map("created_at")
  lastLoginAt  DateTime? @map("last_login_at")

  @@map("admin_users")
}
